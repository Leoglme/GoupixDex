# Bundled defaults for the PyInstaller desktop sidecar.
# CI may overwrite this file before the build.
# Users can override with .env next to the installed worker, or %LOCALAPPDATA%\GoupixDex\.env on Windows.
VINTED_BROWSER_HEADLESS=false
VINTED_BROWSER_DISCREET=false
VINTED_BROWSER_DISCREET_MINIMIZE=false
VINTED_BROWSER_DISCREET_X=0
VINTED_BROWSER_DISCREET_Y=0
